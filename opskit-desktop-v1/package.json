{
  "name": "opskit-desktop-v1",
  "version": "1.1.0",
  "description": "OpsKit Desktop V1 \u2014 local Electron multi-provider AI chat client for Cohere Command A and Anthropic Claude.",
  "type": "module",
  "main": "src/main/main.mjs",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "test:cohere": "node scripts/cohere-risk-01.mjs",
    "pack:dir": "electron-builder --dir",
    "dist:win": "electron-builder --win nsis portable"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@github/keytar": "^7.10.6",
    "cohere-ai": "^8.0.0",
    "electron-store": "^11.0.2",
    "keytar": "^7.9.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.rabitstudios.opskitdesktop",
    "productName": "OpsKit Desktop",
    "asar": true,
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/OpsKit_Quick_Setup.txt",
        "to": "assets/OpsKit_Quick_Setup.txt"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "artifactName": "OpsKit-Desktop-${version}-${arch}.${ext}"
    }
  },
  "engines": {
    "node": ">=22"
  }
}
